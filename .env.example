# PostgreSQL Database Settings
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password_change_me
POSTGRES_DB=example_db

# Go API Backend Settings
ADMIN_TOKEN=example_admin_token_change_me
CLEANUP_INTERVAL=5m

# Redis Settings (Optional)
# REDIS_URL=redis://localhost:6379/0

# Single S3 File Storage Settings (Optional)
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# Multi-S3 File Storage Settings (Optional - overrides single S3_BUCKET if provided)
# Register multiple S3-compatible providers (comma-separated) to distribute uploads and combine free tiers.
# S3_PROVIDERS=FILEBASE,CLOUDFLARE

# Provider 1: Filebase example
# S3_FILEBASE_BUCKET=darkcopy-filebase
# S3_FILEBASE_REGION=us-east-1
# S3_FILEBASE_ENDPOINT=https://s3.filebase.io
# S3_FILEBASE_ACCESS_KEY=your-filebase-access-key
# S3_FILEBASE_SECRET_KEY=your-filebase-secret-key

# Provider 2: Cloudflare R2 example
# S3_CLOUDFLARE_BUCKET=darkcopy-r2
# S3_CLOUDFLARE_REGION=auto
# S3_CLOUDFLARE_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
# S3_CLOUDFLARE_ACCESS_KEY=your-r2-access-key
# S3_CLOUDFLARE_SECRET_KEY=your-r2-secret-key
