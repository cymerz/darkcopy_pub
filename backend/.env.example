# Server configuration
PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/darkcopy?sslmode=disable

# Directory for uploaded files
UPLOAD_DIR=./uploads

# How often the background sweep deletes expired pastes/files from the
# database and disk (Go duration, e.g. "30s", "5m", "1h"). Defaults to 5m.
# An initial sweep also runs at startup regardless of this value.
CLEANUP_INTERVAL=5m

# Admin API token. Leave empty to fully disable the hidden admin API.
# When set, admin endpoints under /admin require this token via the
# "X-Admin-Token" header (or "Authorization: Bearer <token>").
# Use a long, random value in production.
ADMIN_TOKEN=

# S3 File Storage configuration (optional).
# If S3_BUCKET is provided, the server will store uploaded files on S3-compatible cloud storage
# instead of the local filesystem. Leave empty to fallback to local storage (UPLOAD_DIR).
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Multi-S3 File Storage configuration (optional - overrides single S3_BUCKET if provided).
# Register multiple S3-compatible providers (comma-separated, case-insensitive) to distribute uploads and combine free tiers.
# Each provider listed below must have its prefix-specific credentials configured.
# S3_PROVIDERS=FILEBASE,CLOUDFLARE

# Provider 1: Filebase example
# S3_FILEBASE_BUCKET=darkcopy-filebase
# S3_FILEBASE_REGION=us-east-1
# S3_FILEBASE_ENDPOINT=https://s3.filebase.io
# S3_FILEBASE_ACCESS_KEY=your-filebase-access-key
# S3_FILEBASE_SECRET_KEY=your-filebase-secret-key

# Provider 2: Cloudflare R2 example
# S3_CLOUDFLARE_BUCKET=darkcopy-r2
# S3_CLOUDFLARE_REGION=auto
# S3_CLOUDFLARE_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
# S3_CLOUDFLARE_ACCESS_KEY=your-r2-access-key
# S3_CLOUDFLARE_SECRET_KEY=your-r2-secret-key

